# Twitter API 凭证 (OAuth 1.0 - 推荐用于发推)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# 可选：OAuth 2.0 Bearer Token (仅用于读取)
TWITTER_BEARER_TOKEN=

# AI 配置
# 可使用 OpenAI 或兼容 OpenAI API 的服务
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=
# GitHub Copilot (GitHub Models) 配置
# 注意：你需要从 https://github.com/marketplace/models 获取 Token
OPENAI_API_KEY=
OPENAI_BASE_URL=https://models.inference.ai.azure.com
AI_MODEL=gpt-4.1-mini

# 可选：全局提示词
AI_SYSTEM_PROMPT=你是一个推特博主。
AI_REPLY_PROMPT=请根据上下文简短地回复这条推文，不要超过140个字。

# 运行时长（小时）
# -1 表示永不退出
RUN_HOURS=-1
