# Twitter API 凭证 (OAuth 1.0 - 推荐用于发推)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# 可选：OAuth 2.0 Bearer Token (仅用于读取)
TWITTER_BEARER_TOKEN=your_bearer_token

# AI 配置
# 可使用 OpenAI 或兼容 OpenAI API 的服务
OPENAI_API_KEY=your_openai_or_github_models_token
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# 可选：全局提示词
AI_SYSTEM_PROMPT=你是一个推特博主。
AI_REPLY_PROMPT=请根据上下文简短地回复这条推文，不要超过140个字。

# 运行时长（小时）
# -1 表示永不退出
RUN_HOURS=-1
